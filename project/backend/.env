PORT=3001
NODE_ENV=development
# URL-encode the password and explicitly disable SSL in the connection string
DATABASE_URL=postgresql://postgres:Admin%40123@127.0.0.1:5433/bitcoin_ira?sslmode=disable

# PostgreSQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=bitcoin_ira
DB_USER=postgres
DB_PASSWORD=Admin@123

# Explicit PG env vars for node-postgres (keep in sync with DB_*)
PGHOST=127.0.0.1
PGPORT=5433
PGDATABASE=bitcoin_ira
PGUSER=postgres
PGPASSWORD=Admin@123
PGSSLMODE=disable

# Optional: enable node-postgres debug and prefer IPv4 name resolution
DEBUG=pg
NODE_OPTIONS=--dns-result-order=ipv4first

# Enable showing stack traces in dev and increase log verbosity (remove in production)
SHOW_STACK=true
LOG_LEVEL=debug

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000